<Window x:Class="NetFloat.Windows.FaceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:NetFloat.Windows"
        mc:Ignorable="d"
        Title="FaceWindow" ShowInTaskbar="False" 
        Height="160" Width="170"
        WindowStyle="None" ResizeMode="NoResize"   Topmost="True"  Background="Transparent"  AllowsTransparency="True"    Cursor="Hand">
    <Grid Background="Transparent" >
        <Image x:Name="OpenCharacterImage" Width="148" Height="148" Opacity="0"
               HorizontalAlignment="Center" VerticalAlignment="Center"
               Source="pack://application:,,,/res/nailong_eater_open.png"/>
        <Canvas x:Name="EffectCanvas" IsHitTestVisible="False" />
        <Image x:Name="ClosedCharacterImage" Width="148" Height="148" Opacity="0"
               HorizontalAlignment="Center" VerticalAlignment="Center"
               Source="pack://application:,,,/res/nailong_eater_closed.png"/>
    </Grid>
</Window>
